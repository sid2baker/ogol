defmodule Ogol.Corpus.LiteralHardwareRefCanonical do
  use Ogol.Machine

  machine do
    name(:literal_hardware_ref)
    meaning("Exercises canonical hardware binding metadata")
    hardware_ref([
      %{slave: :inputs, facts: [:ready?]},
      %{slave: :outputs, outputs: [:armed?], meta: %{zone: :main}}
    ])
  end

  boundary do
    request(:start)
    output(:armed?, :boolean, default: false)
    signal(:armed)
  end

  states do
    state :idle do
      initial?(true)
      set_output(:armed?, false)
    end

    state :armed do
      set_output(:armed?, true)
    end
  end

  transitions do
    transition :idle, :armed do
      on({:request, :start})
      signal(:armed)
      reply(:ok)
    end
  end
end
