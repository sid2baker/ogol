defmodule Ogol.Corpus.LiteralHardwareRefReordered do
  use Ogol.Machine

  machine do
    hardware_ref([
      %{outputs: [:armed?], meta: %{zone: :main}, slave: :outputs},
      %{facts: [:ready?], slave: :inputs}
    ])
    meaning("Exercises canonical hardware binding metadata")
    name(:literal_hardware_ref)
  end

  transitions do
    transition :idle, :armed do
      on({:request, :start})
      signal(:armed)
      reply(:ok)
    end
  end

  boundary do
    signal(:armed)
    output(:armed?, :boolean, default: false)
    request(:start)
  end

  states do
    state :armed do
      set_output(:armed?, true)
    end

    state :idle do
      set_output(:armed?, false)
      initial?(true)
    end
  end
end
