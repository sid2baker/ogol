defmodule Ogol.Corpus.NonLiteralHardwareRef do
  use Ogol.Machine

  machine do
    name(:non_literal_hardware_ref)
    hardware_ref(build_ref())
  end

  states do
    state :idle do
      initial?(true)
    end
  end

  transitions do
  end

  defp build_ref, do: [%{slave: :inputs, facts: [:ready?]}]
end
